# App ports exposed on host
API_PORT=3000
ADMIN_PORT=8080

# Admin → API base URL (build-time). Leave empty to auto-use same host + :3000
# VITE_API_URL=http://176.98.182.112:3000

# API runtime
PORT=3000
JWT_SECRET=replace-with-strong-secret
YOUTUBE_API_KEY=

ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=change-this-password

# Postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=yt_admin
DB_PASSWORD=change-this-db-password
DB_NAME=yt_admin
