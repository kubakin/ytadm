# App ports exposed on host
API_PORT=3000
ADMIN_PORT=8080

# Admin frontend API base URL (embedded at build time)
VITE_API_URL=http://localhost:3000

# API runtime
PORT=3000
JWT_SECRET=replace-with-strong-secret
YOUTUBE_API_KEY=

ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=change-this-password

# Postgres
DB_HOST=postgres
DB_PORT=5432
DB_USER=yt_admin
